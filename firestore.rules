rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function isPendingInvitation() {
      return resource.data.status == "PENDING";
    }

    function isInvitationOwner() {
      return signedIn() && resource.data.userUid == request.auth.uid;
    }

    function isInvitedGuardian() {
      return signedIn() && (
        resource.data.guardianUid == request.auth.uid ||
        (
          resource.data.guardianUid == null &&
          resource.data.guardianNormalizedEmail == userEmail()
        )
      );
    }

    function isAlertUser() {
      return signedIn() && resource.data.userUid == request.auth.uid;
    }

    function isAlertGuardian() {
      return signedIn() && resource.data.guardianUid == request.auth.uid;
    }

    match /account_profiles/{uid} {
      allow read: if signedIn();

      allow create: if isSelf(uid)
        && request.resource.data.accountType in ["USER", "GUARDIAN"];

      allow update: if isSelf(uid)
        && (!resource.data.keys().hasAny(["accountType"]) || request.resource.data.accountType == resource.data.accountType)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["guardianIds"])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["dependentIds"]) ||
          request.resource.data.accountType == "GUARDIAN"
        );

      allow delete: if false;
    }

    match /guardian_invitations/{invitationId} {
      allow read: if signedIn() && (
        resource.data.userUid == request.auth.uid ||
        resource.data.guardianUid == request.auth.uid ||
        resource.data.guardianNormalizedEmail == userEmail()
      );

      allow create: if signedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.status == "PENDING"
        && request.resource.data.guardianNormalizedEmail is string
        && request.resource.data.guardianNormalizedEmail.size() > 0;

      allow update: if isPendingInvitation()
        && isInvitedGuardian()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "guardianUid",
          "guardianDisplayName",
          "guardianEmail",
          "guardianNormalizedEmail",
          "status",
          "respondedAt"
        ])
        && request.resource.data.userUid == resource.data.userUid
        && request.resource.data.status in ["ACCEPTED", "DECLINED"]
        && request.resource.data.guardianUid == request.auth.uid
        && request.resource.data.guardianNormalizedEmail == userEmail();

      allow delete: if signedIn() && resource.data.userUid == request.auth.uid;
    }

    match /emergency_alerts/{alertId} {
      allow read: if signedIn() && (
        resource.data.userUid == request.auth.uid ||
        resource.data.guardianUid == request.auth.uid
      );

      allow create: if signedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.guardianUid is string
        && request.resource.data.phraseText is string
        && request.resource.data.type in ["NOTIFICATION", "CALL_REQUEST"];

      allow update: if signedIn()
        && resource.data.guardianUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readAt"]);

      allow delete: if signedIn() && (
        resource.data.userUid == request.auth.uid ||
        resource.data.guardianUid == request.auth.uid
      );
    }
  }
}
